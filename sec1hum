      <input type="text" id="payment-url-input" class="w-full p-2 border border-neutral-300 text-xs rounded-lg mb-3 focus:outline-none focus:ring-1 focus:ring-black" placeholder="https://checkout.stripe.com/..." value="https://krunch.sg/sec1hum/">
      
      <button onclick="savePaymentLink()" class="w-full py-2 bg-black text-white rounded-lg text-xs font-bold hover:bg-neutral-855 transition-all-300">
        Save & Update Buttons
      </button>
