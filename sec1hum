    </div>
  </div>

  <!-- JAVASCRIPT LOGIC -->
  <script>
    // Initialize icons
    lucide.createIcons();

    // Default payment link fallbacks
    let currentPaymentUrl = "https://krunch.sg/sec1hum/";

    // Check localStorage on load
    window.onload = function() {
      const savedLink = localStorage.getItem("krunch_payment_link");
      if (savedLink) {
        currentPaymentUrl = savedLink;
        document.getElementById("payment-url-input").value = savedLink;
      }
      updateEnrolButtons();
    };

    // Update links
    function updateEnrolButtons() {
      const btns = document.querySelectorAll('.enrol-btn');
      btns.forEach(btn => {
        btn.setAttribute('href', currentPaymentUrl);
      });
    }

    // New UX: Interactive Specs Accordion toggler inside Timetable segment
    function toggleSpecAccordion(subj) {
      const content = document.getElementById(`accordion-content-${subj}`);
      const icon = document.getElementById(`accordion-icon-${subj}`);
      if (content.classList.contains('hidden')) {
        content.classList.remove('hidden');
        icon.classList.add('rotate-180');
      } else {
        content.classList.add('hidden');
        icon.classList.remove('rotate-180');
      }
    }

    // Toggle Registration Terms T&C
    function toggleRegistrationTerms() {
      const content = document.getElementById('terms-content');
      const icon = document.getElementById('terms-icon');
      if (content.classList.contains('hidden')) {
        content.classList.remove('hidden');
        icon.classList.add('rotate-45');
      } else {
        content.classList.add('hidden');
        icon.classList.remove('rotate-45');
      }
    }

    // Toggle FAQ answers
    function toggleFaq(num) {
      const ans = document.getElementById(`faq-ans-${num}`);
      const icon = document.getElementById(`faq-icon-${num}`);
      
      if (ans.classList.contains('hidden')) {
        ans.classList.remove('hidden');
        icon.classList.add('rotate-45');
      } else {
        ans.classList.add('hidden');
        icon.classList.remove('rotate-45');
      }
    }

    // Settings panel toggles
    function toggleConfig() {
      const card = document.getElementById('config-card');
      card.classList.toggle('hidden');
    }

    // Save payment configuration links
    function savePaymentLink() {
      const val = document.getElementById('payment-url-input').value.trim();
      if (val) {
        currentPaymentUrl = val;
        localStorage.setItem("krunch_payment_link", val);
        updateEnrolButtons();
        
        const status = document.getElementById('config-status');
        status.classList.remove('hidden');
        setTimeout(() => {
          status.classList.add('hidden');
          toggleConfig();
        }, 1500);
      }
    }
  </script>
